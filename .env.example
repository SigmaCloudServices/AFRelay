# ── Legacy (kept for backward compat) ─────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret

# ── Docs (Swagger UI) ──────────────────────────────────────────────────────────
DOCS_USERNAME=docs
DOCS_PASSWORD=change-me-docs-password

# ── AFIP Environment ──────────────────────────────────────────────────────────
WSAA_PRODUCTION=false
WSFE_PRODUCTION=false
WSPCI_PRODUCTION=false

# ── Multitenant — Session & Encryption ────────────────────────────────────────
# Used for: Starlette SessionMiddleware + Fernet key derivation for private keys
# IMPORTANT: Use a strong random secret (openssl rand -hex 32)
SECRET_KEY=change-me-minimum-32-chars-random-secret-here!

# ── Multitenant — Admin credentials ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe1!
ADMIN_API_KEY=change-me-admin-api-key

# ── Multitenant — Token scheduler ─────────────────────────────────────────────
AFIP_TOKEN_WATCHDOG_MINUTES=5
WSFE_TOKEN_RENEW_BEFORE_MINUTES=15
WSPCI_TOKEN_RENEW_BEFORE_MINUTES=15
